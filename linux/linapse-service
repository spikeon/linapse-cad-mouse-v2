#!/usr/bin/env python3
"""
Linapse service — serial + WebSocket bridge for CAD Mouse MK2.

Owns /dev/ttyACM0, dispatches button/tap actions, and exposes
ws://localhost:13000 for the Linapse configurator and other clients.

Replaces spnav-buttons. Clients send the same commands as the raw serial
protocol (e.g. "led color FF2400"), and receive serial responses back.
TAP: events are also broadcast to all connected WebSocket clients.

WebSocket protocol (text frames):
  Client → server:  any firmware serial command, e.g. "led color FF2400"
  Server → client:  firmware responses ("OK", "ERR ...") and events ("TAP:top:1")
"""

import asyncio
import glob
import json
import os
import select
import signal
import serial
import struct
import subprocess
import threading
import time
from pathlib import Path

try:
    import websockets
    import websockets.exceptions
except ImportError:
    raise SystemExit("websockets not installed — run: pip install --break-system-packages websockets")

# ── Config ────────────────────────────────────────────────────────────────────

ACTIONS_PATH    = Path.home() / ".config" / "cad-mouse" / "actions.json"
YDOTOOL_SOCKET  = f"/run/user/{os.getuid()}/.ydotool_socket"
WS_HOST         = "localhost"
WS_PORT         = 13000
SERIAL_BAUD     = 115200
BUTTON_REPORT_ID = 3
CHORD_WINDOW    = 0.05
SCROLL_INTERVAL = 0.05

DIR_MAP = {
    "NegZ": "top", "NegX": "left", "PosX": "right",
    "PosY": "front", "NegY": "back",
}

# ── Shared state ──────────────────────────────────────────────────────────────

_loop: asyncio.AbstractEventLoop = None
_ws_clients: set = set()
_socket_clients: set = set()
_serial_queue: asyncio.Queue = None
_ser_holder: list = [None]  # [serial.Serial | None]
_actions_ref: list = [None]  # [dict | None]
_config_lock = threading.Lock()


# ── Actions ───────────────────────────────────────────────────────────────────

def get_active_mode_config(actions, category):
    if not isinstance(actions, dict):
        actions = {"button_override": False, "buttons": {}, "taps": {}}
    if "modes" in actions:
        current_mode = actions.get("current_mode")
        if current_mode and current_mode in actions["modes"]:
            mode_config = actions["modes"][current_mode]
            return mode_config.get(category, {})
        return {}
    else:
        return actions.get(category, {})

def switch_mode(target_mode):
    global _config_lock
    with _config_lock:
        actions = _actions_ref[0]
        if not actions or not isinstance(actions, dict) or "modes" not in actions:
            return
        if target_mode not in actions["modes"]:
            print(f"[mode] target mode '{target_mode}' does not exist")
            return

        actions["current_mode"] = target_mode

        try:
            ACTIONS_PATH.parent.mkdir(parents=True, exist_ok=True)
            tmp_path = ACTIONS_PATH.with_suffix(".tmp")
            with open(tmp_path, "w") as f:
                json.dump(actions, f, indent=2)
            os.replace(tmp_path, ACTIONS_PATH)
            print(f"[mode] switched to '{target_mode}' and saved configuration")
        except Exception as e:
            print(f"[mode] error saving configuration: {e}")

    led_config = actions["modes"][target_mode].get("led", {})
    effect = led_config.get("effect", "solid")
    color = led_config.get("color", "FFFFFF")
    brightness = led_config.get("brightness", 128)

    if _loop and _serial_queue:
        async def queue_cmds():
            await _serial_queue.put(f"led effect {effect}")
            await _serial_queue.put(f"led color {color}")
            await _serial_queue.put(f"led brightness {brightness}")
        asyncio.run_coroutine_threadsafe(queue_cmds(), _loop)

    _broadcast_from_thread(f"MODE:{target_mode}")

def load_actions():
    global _config_lock
    with _config_lock:
        actions = None
        file_existed = False
        parsing_error = False
        try:
            if ACTIONS_PATH.exists():
                file_existed = True
                with open(ACTIONS_PATH) as f:
                    actions = json.load(f)
        except Exception as e:
            print(f"[actions] {e}")
            parsing_error = True
            if file_existed and _actions_ref[0] is not None:
                return _actions_ref[0]

        if actions is None or not isinstance(actions, dict):
            actions = {"button_override": False, "buttons": {}, "taps": {}}

        migrated = False
        if "buttons" in actions or "taps" in actions:
            legacy_buttons = actions.pop("buttons", {})
            legacy_taps = actions.pop("taps", {})
            actions["modes"] = {
                "Default": {
                    "buttons": legacy_buttons,
                    "taps": legacy_taps,
                    "led": {"effect": "solid", "color": "FFFFFF", "brightness": 128}
                }
            }
            actions["current_mode"] = "Default"
            migrated = True

        if migrated and not parsing_error:
            try:
                ACTIONS_PATH.parent.mkdir(parents=True, exist_ok=True)
                tmp_path = ACTIONS_PATH.with_suffix(".tmp")
                with open(tmp_path, "w") as f:
                    json.dump(actions, f, indent=2)
                os.replace(tmp_path, ACTIONS_PATH)
                print(f"[actions] migrated and saved to {ACTIONS_PATH}")
            except Exception as e:
                print(f"[actions] failed to save migrated actions: {e}")
        return actions

def ydotool(*args):
    env = os.environ.copy()
    env["YDOTOOL_SOCKET"] = YDOTOOL_SOCKET
    flat_args = []
    for arg in args:
        if isinstance(arg, str):
            flat_args.extend(arg.split())
        else:
            flat_args.append(arg)
    try:
        subprocess.Popen(["ydotool"] + flat_args, env=env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception as e:
        print(f"[ydotool] spawn error: {e}")

_MOUSE_BTN = {"left": 0xC0, "right": 0xC1, "middle": 0xC2}


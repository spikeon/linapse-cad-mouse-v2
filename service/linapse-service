def _save_actions(json_str, actions_ref=None):
    return config.save_actions(json_str)

def _get_current_module():
    name = globals().get("__name__")
    if name and name in sys.modules:
        mod = sys.modules[name]
        if getattr(mod, "__dict__", None) is globals():
            return mod
    for mod in list(sys.modules.values()):
        if getattr(mod, "__dict__", None) is globals():
            return mod
    frame = sys._getframe(0)
    while frame:
        for val in list(frame.f_locals.values()):
            if isinstance(val, types.ModuleType) and val.__dict__ is globals():
                return val
        frame = frame.f_back
    return None

_curr_mod = _get_current_module()
if _curr_mod:
    _curr_mod.__class__ = LinapseServiceModule

# ── Entrypoint logic ─────────────────────────────────────────────────────────

async def serial_writer():
    while True:
        cmd = await state.serial_queue.get()
        ser = state.ser_holder[0]
        if ser:
            try:
                ser.write((cmd.strip() + "\n").encode())
            except Exception as e:
                print(f"[serial] write error: {e}")
        state.serial_queue.task_done()

async def main():
    state.loop = asyncio.get_running_loop()
    state.serial_queue = asyncio.Queue()

    main_task = asyncio.current_task()

    def handle_signal():
        print("[main] signal received, cancelling main task")
        main_task.cancel()

    if sys.platform != "win32":
        state.loop.add_signal_handler(signal.SIGINT, handle_signal)
        state.loop.add_signal_handler(signal.SIGTERM, handle_signal)

    state.actions_ref[0] = config.load_actions()
    actions_ref = state.actions_ref

    threading.Thread(target=serial_port.serial_thread,  args=(actions_ref,), daemon=True).start()
    threading.Thread(target=hid.hid_thread,     args=(actions_ref,), daemon=True).start()
    threading.Thread(target=config.config_watcher, args=(actions_ref,), daemon=True).start()
    threading.Thread(target=volume.volume_watcher, daemon=True).start()
    threading.Thread(target=equalizer.equalizer_watcher, args=(actions_ref,), daemon=True).start()

    def updater_loop():
        time.sleep(5)  # Wait for WebSocket/Serial to initialize
        while True:
            try:
                updater.check_for_updates(quiet=True)
            except Exception as e:
                print(f"[updater] background check error: {e}")
            time.sleep(86400)
    threading.Thread(target=updater_loop, daemon=True).start()

    asyncio.create_task(serial_writer())

    browser_bridge_task = None
    if (
        sys.platform not in ("win32", "darwin")
        and "PYTEST_CURRENT_TEST" not in os.environ
        and os.environ.get("LINAPSE_SKIP_BROWSER_BRIDGE") != "1"
    ):
        from linapse import browser_bridge
        browser_bridge_task = asyncio.create_task(browser_bridge.serve())

    unix_server = None
    socket_path = None
    if sys.platform not in ("win32", "darwin"):
        try:
            # Unix Socket Setup
            socket_path = Path(f"/run/user/{os.getuid()}/spnav.sock")
            socket_path.parent.mkdir(parents=True, exist_ok=True)
            if socket_path.exists():
                try:
                    socket_path.unlink()
                except Exception as e:
                    print(f"[sock] failed to unlink stale socket: {e}")

            print(f"[sock] server starting on {socket_path}")
            unix_server = await asyncio.start_unix_server(spnav.handle_socket_client, path=str(socket_path))
        except Exception as e:
            print(f"[sock] error setting up unix socket: {e}")

    handler = lambda ws: websocket.ws_handler(ws, actions_ref)
    print(f"[ws] server starting on ws://{WS_HOST}:{WS_PORT}")
    import websockets
    try:
        async with websockets.serve(handler, WS_HOST, WS_PORT):
            await asyncio.Future()  # run forever
    except asyncio.CancelledError:
        pass
    finally:
        if browser_bridge_task is not None:
            browser_bridge_task.cancel()
            try:
                await browser_bridge_task
            except asyncio.CancelledError:
                pass
        print("[sock] server shutting down")
        for writer in list(state.socket_clients):
            try:
                writer.close()
            except Exception:
                pass
        if unix_server:
            unix_server.close()
            try:
                loop = asyncio.get_running_loop()
                if loop.is_running():
                    await unix_server.wait_closed()
            except RuntimeError:
                pass
        if socket_path and socket_path.exists():
            try:
                socket_path.unlink()
            except Exception as e:
                print(f"[sock] failed to unlink socket on shutdown: {e}")

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        print("[main] keyboard interrupt, exiting")

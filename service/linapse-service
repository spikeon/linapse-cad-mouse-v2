class ButtonClickState:
    def __init__(self, btn):
        self.btn = btn
        self.click_count = 0
        self.timer = None
        self.released = False

_click_states = {0: ButtonClickState(0), 1: ButtonClickState(1)}

def reset_click_states():
    for state in _click_states.values():
        if state.timer:
            state.timer.cancel()
            state.timer = None
        state.click_count = 0
        state.released = False

_held = set()
_chord_fired = False
_timers = {}
_scroll_threads = {}

def _scroll_loop(btn, stop_event, actions):
    while not stop_event.is_set():
        mode_buttons = get_active_mode_config(actions, "buttons")
        act = mode_buttons.get(f"{btn}:1")
        if not act:
            act = mode_buttons.get(str(btn), {"action": "scroll_down" if btn == 0 else "scroll_up"})
        dispatch(act)
        time.sleep(SCROLL_INTERVAL)

def _on_single(btn, actions):
    if _chord_fired:
        return
    _broadcast_from_thread(f"BUTTON:{btn}:1")
    if actions.get("button_override", False):
        return
    mode_buttons = get_active_mode_config(actions, "buttons")
    act = mode_buttons.get(f"{btn}:1")
    if not act:
        act = mode_buttons.get(str(btn), {"action": "scroll_down" if btn == 0 else "scroll_up"})
    if act.get("action") in ("scroll_up", "scroll_down"):
        stop_event = threading.Event()
        t = threading.Thread(target=_scroll_loop, args=(btn, stop_event, actions), daemon=True)
        _scroll_threads[btn] = (t, stop_event)
        t.start()
    else:
        dispatch(act)

def _on_chord(actions):
    _broadcast_from_thread("BUTTON:chord:1")
    mode_buttons = get_active_mode_config(actions, "buttons")
    act = mode_buttons.get("chord", {"action": "key", "value": "shift+7"})
    dispatch(act)

def _fire_multi_click(btn, count, actions):
    if _chord_fired:
        return
    _broadcast_from_thread(f"BUTTON:{btn}:{count}")
    if actions.get("button_override", False):
        return
    mode_buttons = get_active_mode_config(actions, "buttons")
    act = mode_buttons.get(f"{btn}:{count}")
    if not act and count == 1:
        act = mode_buttons.get(str(btn), {"action": "scroll_down" if btn == 0 else "scroll_up"})
    if act:
        dispatch(act)

def _on_press(btn, actions):
    global _chord_fired
    _held.add(btn)
    if len(_held) == 2:
        _chord_fired = True
        for t in _timers.values():
            t.cancel()
        _timers.clear()
        for state in _click_states.values():
            if state.timer:
                state.timer.cancel()
                state.timer = None
            state.click_count = 0
        _on_chord(actions)
        return

    mode_buttons = get_active_mode_config(actions, "buttons")
    has_double = f"{btn}:2" in mode_buttons

    if has_double:
        state = _click_states[btn]
        if state.timer:
            state.timer.cancel()
            state.timer = None
            state.click_count += 1
        else:
            state.click_count = 1
        state.released = False
    else:
        t = threading.Timer(CHORD_WINDOW, _on_single, args=[btn, actions])
        _timers[btn] = t
        t.start()

def _on_release(btn, actions=None):
    global _chord_fired
    _held.discard(btn)
    if btn in _timers:
        _timers.pop(btn).cancel()
    if btn in _scroll_threads:
        _, stop_event = _scroll_threads.pop(btn)
        stop_event.set()
    if not _held:
        _chord_fired = False

    if actions is None:
        actions = _actions_ref[0] or {}

    state = _click_states.get(btn)
    if state and state.click_count > 0 and not state.released:
        state.released = True
        def fire():
            _fire_multi_click(btn, state.click_count, actions)
            state.click_count = 0
            state.timer = None
        state.timer = threading.Timer(0.25, fire)
        state.timer.start()

    _broadcast_from_thread(f"BUTTON:{btn}:0")

# ── Broadcast helper (thread-safe) ────────────────────────────────────────────

def _broadcast_from_thread(msg: str):
    if _loop:
        fut = asyncio.run_coroutine_threadsafe(_broadcast(msg), _loop)
        def cb(f):
            try:
                f.result()
            except Exception as e:
                print(f"[broadcast] exception: {e}", flush=True)
        fut.add_done_callback(cb)

async def _broadcast(msg: str):
    dead = set()
    for ws in list(_ws_clients):
        try:
            await ws.send(msg)
        except Exception:
            dead.add(ws)
    _ws_clients.difference_update(dead)

# ── Unix Socket Helpers ───────────────────────────────────────────────────────

async def handle_socket_client(reader: asyncio.StreamReader, writer: asyncio.StreamWriter):
    _socket_clients.add(writer)
    print(f"[sock] client connected ({len(_socket_clients)} total)")
    try:
        while not writer.is_closing():
            data = await reader.read(1024)
            if not data:
                break
    except (asyncio.CancelledError, ConnectionError):
        pass
    except Exception as e:
        print(f"[sock] client error: {e}")
    finally:
        _socket_clients.discard(writer)
        _socket_clients_busy.discard(writer)
        try:
            writer.close()
            try:
                loop = asyncio.get_running_loop()
                if loop.is_running():
                    await writer.wait_closed()
            except RuntimeError:
                pass
        except Exception:
            pass
        print(f"[sock] client disconnected ({len(_socket_clients)} total)")

async def _broadcast_socket(packet: bytes):
    if not _socket_clients:
        return
    for writer in list(_socket_clients):
        try:
            if writer.is_closing():
                _socket_clients.discard(writer)
                continue
            if writer.transport and writer.transport.get_write_buffer_size() > 65536:
                print(f"[sock] discarding slow client (buffer size={writer.transport.get_write_buffer_size()})")
                _socket_clients.discard(writer)
                try:
                    writer.close()
                except Exception:
                    pass
                continue
            writer.write(packet)
        except Exception as e:
            print(f"[sock] write error: {e}")
            _socket_clients.discard(writer)
            try:
                writer.close()
            except Exception:
                pass
    await asyncio.sleep(0)

def _broadcast_socket_from_thread(packet: bytes):
    if _loop:
        fut = asyncio.run_coroutine_threadsafe(_broadcast_socket(packet), _loop)
        def cb(f):
            try:
                f.result()
            except Exception as e:
                print(f"[broadcast_socket] exception: {e}", flush=True)
        fut.add_done_callback(cb)

# ── HID thread ────────────────────────────────────────────────────────────────

def hid_thread(actions_ref):
    if sys.platform in ("win32", "darwin"):
        print("[hid] disabled on Windows/macOS")
        return
    while True:
        candidates = (
            glob.glob("/dev/input/by-id/usb-*CAD_Mouse*-if02-hidraw") +
            glob.glob("/dev/input/by-id/usb-Seeed_Studio*-if02-hidraw")
        )
        if not candidates:
            time.sleep(3)
            continue
        try:
            with open(candidates[0], "rb") as fd:
                os.set_blocking(fd.fileno(), False)
                prev_bits = 0
                print(f"[hid] watching {fd.name}")
                while True:
                    r, _, _ = select.select([fd], [], [], 1)
                    if not r:
                        continue
                    data = fd.read(64)
                    if not data:
                        raise OSError("no data (disconnected)")
                    if data[0] != BUTTON_REPORT_ID:
                        continue
                    bits = data[1] & 0x03
                    if bits == prev_bits:
                        continue
                    for btn in range(2):
                        mask = 1 << btn
                        was = bool(prev_bits & mask)
                        now = bool(bits & mask)
                        if now and not was:
                            _on_press(btn, actions_ref[0])
                        elif was and not now:
                            _on_release(btn)
                    prev_bits = bits
        except (OSError, IOError) as e:
            print(f"[hid] error/disconnect: {e} — retrying in 3s")
            for btn in list(_held):
                _on_release(btn)
            time.sleep(3)

# ── Serial thread ─────────────────────────────────────────────────────────────

def find_serial(actions_ref=None):
    if actions_ref and actions_ref[0] and isinstance(actions_ref[0], dict):
        manual_port = actions_ref[0].get("serial_port") or actions_ref[0].get("port")
        if manual_port:
            return manual_port

    try:
        for p in serial.tools.list_ports.comports():
            vid = getattr(p, "vid", None)
            desc = getattr(p, "description", "") or ""
            prod = getattr(p, "product", "") or ""
            if vid == 0x2886:
                return p.device
            for term in ("Seeed", "CAD Mouse", "CAD_Mouse"):
                if term in desc or term in prod:
                    return p.device
    except Exception as e:
        print(f"[serial] error listing comports: {e}")

    m = (glob.glob("/dev/serial/by-id/usb-Seeed_Studio_CAD_Mouse*") +
         glob.glob("/dev/ttyACM*"))
    return m[0] if m else None

def serial_thread(actions_ref):
    global _rx_scroll_accumulator, _rz_scrub_accumulator, _rx_volume_accumulator
    port = find_serial(actions_ref)
    if not port:
        print("[serial] no serial port found — retrying in 5s")
        while True:
            time.sleep(5)
            port = find_serial(actions_ref)
            if port:
                break
    while True:
        try:
            ser = serial.Serial(port, SERIAL_BAUD, timeout=1.0)
            _ser_holder[0] = ser
            print(f"[serial] connected to {port}")
            
            # Send initial active mode's LED settings to the device so they are in sync on startup.
            actions = actions_ref[0]
            if actions and "modes" in actions:
                current_mode = actions.get("current_mode", "Default")
                if current_mode in actions["modes"]:
                    led_config = actions["modes"][current_mode].get("led", {})
                    effect = led_config.get("effect", "solid")
                    color = led_config.get("color", "FFFFFF")
                    brightness = led_config.get("brightness", 128)
                    try:
                        ser.write(f"led effect {effect}\n".encode())
                        ser.write(f"led color {color}\n".encode())
                        ser.write(f"led brightness {brightness}\n".encode())
                    except Exception as e:
                        print(f"[serial] failed to write initial LED commands: {e}")
                        
            while True:
                line = ser.readline().decode(errors="replace").strip()
                if not line:
                    continue
                if line.startswith("TAP:"):
                    parts = line.split(":")
                    if len(parts) == 3:
                        _, fw_dir, count_str = parts
                        human = DIR_MAP.get(fw_dir)
                        if human:
                            key = f"{human}:{count_str}"
                            mode_taps = get_active_mode_config(actions_ref[0], "taps")
                            act = mode_taps.get(key)
                            if act:
                                print(f"[tap] {key} → {act}")
                                dispatch(act)
                            _broadcast_from_thread(f"TAP:{human}:{count_str}")
                elif line.startswith(">MOTION:"):
                    current_mode = actions_ref[0].get("current_mode", "Default") if actions_ref[0] else "Default"
                    if current_mode not in ("Browser", "Media"):
                        _broadcast_from_thread(line[1:])  # strip '>' → MOTION:...
                    try:
                        parts = line[8:].split(",")
                        if len(parts) == 6:
                            # Parse floats
                            raw_coords = [float(p) for p in parts]
                            x, y, z, rx, ry, rz = raw_coords
                            
                            if not math.isfinite(x): x = 0.0
                            if not math.isfinite(y): y = 0.0
                            if not math.isfinite(z): z = 0.0
                            if not math.isfinite(rx): rx = 0.0
                            if not math.isfinite(ry): ry = 0.0
                            if not math.isfinite(rz): rz = 0.0
                            
                            # Load sensitivity from config
                            sens = actions_ref[0].get("sensitivity", {}) if actions_ref[0] else {}
                            
                            # Scale each axis depending on sign (positive vs negative direction)
                            x = x * sens.get("x_pos" if x >= 0 else "x_neg", 1.0)
                            y = y * sens.get("y_pos" if y >= 0 else "y_neg", 1.0)
                            z = z * sens.get("z_pos" if z >= 0 else "z_neg", 1.0)
                            rx = rx * sens.get("rx_pos" if rx >= 0 else "rx_neg", 1.0)
                            ry = ry * sens.get("ry_pos" if ry >= 0 else "ry_neg", 1.0)
                            rz = rz * sens.get("rz_pos" if rz >= 0 else "rz_neg", 1.0)
                            
                            # Apply user-configured axis inversions
                            inv = actions_ref[0].get("inversion", {}) if actions_ref[0] else {}
                            if inv.get("x", False): x = -x
                            if inv.get("y", False): y = -y
                            if inv.get("z", False): z = -z
                            if inv.get("rx", False): rx = -rx
                            if inv.get("ry", False): ry = -ry
                            if inv.get("rz", False): rz = -rz

                            if current_mode == "Browser":
                                if abs(rx) > 15.0:
                                    _rx_scroll_accumulator += rx
                                else:
                                    _rx_scroll_accumulator *= 0.8

                                if _rx_scroll_accumulator >= 150.0:
                                    scrolls = int(_rx_scroll_accumulator // 150.0)
                                    dispatch({"action": "mouse_scroll", "direction": "down", "amount": scrolls})
                                    _rx_scroll_accumulator -= scrolls * 150.0
                                elif _rx_scroll_accumulator <= -150.0:
                                    scrolls = int(-_rx_scroll_accumulator // 150.0)
                                    dispatch({"action": "mouse_scroll", "direction": "up", "amount": scrolls})
                                    _rx_scroll_accumulator += scrolls * 150.0

                            elif current_mode == "Media":
                                if abs(rz) > 15.0:
                                    _rz_scrub_accumulator += rz
                                else:
                                    _rz_scrub_accumulator *= 0.8

                                if _rz_scrub_accumulator >= 200.0:
                                    presses = int(_rz_scrub_accumulator // 200.0)
                                    for _ in range(presses):
                                        dispatch({"action": "key", "value": "right"})
                                    _rz_scrub_accumulator -= presses * 200.0
                                elif _rz_scrub_accumulator <= -200.0:
                                    presses = int(-_rz_scrub_accumulator // 200.0)
                                    for _ in range(presses):
                                        dispatch({"action": "key", "value": "left"})
                                    _rz_scrub_accumulator += presses * 200.0

                                if abs(rx) > 15.0:
                                    _rx_volume_accumulator += rx
                                else:
                                    _rx_volume_accumulator *= 0.8

                                if _rx_volume_accumulator >= 250.0:
                                    presses = int(_rx_volume_accumulator // 250.0)
                                    for _ in range(presses):
                                        dispatch({"action": "key", "value": "volup"})
                                    _rx_volume_accumulator -= presses * 250.0
                                elif _rx_volume_accumulator <= -250.0:
                                    presses = int(-_rx_volume_accumulator // 250.0)
                                    for _ in range(presses):
                                        dispatch({"action": "key", "value": "voldown"})
                                    _rx_volume_accumulator += presses * 250.0

                            if current_mode not in ("Browser", "Media"):
                                # Apply direction inversions for spacenav mapping
                                z = -z
                                y = -y
                                
                                # Round to integers
                                ix = int(round(x))
                                iy = int(round(y))
                                iz = int(round(z))
                                irx = int(round(rx))
                                iry = int(round(ry))
                                irz = int(round(rz))
                                
                                period = 10
                                # Swap Y and Z for both translation and rotation: [0, x, z, y, rx, rz, ry, period]
                                packet = struct.pack("iiiiiiii", 0, ix, iz, iy, irx, irz, iry, period)
                                _broadcast_socket_from_thread(packet)
                    except Exception as e:
                        print(f"[serial] motion parse/pack error: {e}")
                elif not line.startswith(">"):
                    # Command response (OK, ERR ..., JSON from config get, etc.)
                    _broadcast_from_thread(line)
        except serial.SerialException as e:
            _ser_holder[0] = None
            print(f"[serial] {e} — retrying in 3s")
            time.sleep(3)

# ── Config watcher ────────────────────────────────────────────────────────────

def config_watcher(actions_ref):
    last_mtime = 0
    while True:
        try:
            mtime = ACTIONS_PATH.stat().st_mtime
            if mtime != last_mtime:
                last_mtime = mtime
                actions_ref[0] = load_actions()
                print(f"[config] reloaded {ACTIONS_PATH}")
        except FileNotFoundError:
            pass
        time.sleep(2)

# ── Volume watcher ────────────────────────────────────────────────────────────

def volume_watcher():
    import re
    last_val = -1
    while True:
        try:
            vol = -1
            if sys.platform == "win32":
                try:
                    from pycaw.pycaw import AudioUtilities
                    from ctypes import cast, POINTER
                    from comtypes import CLSCTX_ALL
                    from pycaw.pycaw import IAudioEndpointVolume
                    devices = AudioUtilities.GetSpeakers()
                    if devices:
                        interface = devices.Activate(IAudioEndpointVolume._iid_, CLSCTX_ALL, None)
                        volume = cast(interface, POINTER(IAudioEndpointVolume))
                        vol = int(round(volume.GetMasterVolumeLevelScalar() * 100))
                except Exception:
                    pass
            elif sys.platform == "darwin":
                try:
                    out = subprocess.check_output(["osascript", "-e", "output volume of (get volume settings)"], stderr=subprocess.DEVNULL).decode().strip()
                    vol = int(out)
                except Exception:
                    pass
            else: # Linux/other
                try:
                    out = subprocess.check_output(["amixer", "sget", "Master"], stderr=subprocess.DEVNULL).decode()
                    m = re.search(r"\[(\d+)%\]", out)
                    if m:
                        vol = int(m.group(1))
                except Exception:
                    pass
                if vol == -1:
                    try:
                        out = subprocess.check_output(["pactl", "get-sink-volume", "@DEFAULT_SINK@"], stderr=subprocess.DEVNULL).decode()
                        m = re.search(r"(\d+)%", out)
                        if m:
                            vol = int(m.group(1))
                    except Exception:
                        pass

            if vol != -1 and vol != last_val:
                last_val = vol
                if _loop and _serial_queue:
                    _loop.call_soon_threadsafe(_serial_queue.put_nowait, f"volume {vol}")
        except Exception:
            pass
        time.sleep(0.25)

# ── Serial writer (asyncio) ───────────────────────────────────────────────────

async def serial_writer():
    while True:
        cmd = await _serial_queue.get()
        ser = _ser_holder[0]
        if ser:
            try:
                ser.write((cmd.strip() + "\n").encode())
            except Exception as e:
                print(f"[serial] write error: {e}")
        _serial_queue.task_done()

# ── WebSocket handler ─────────────────────────────────────────────────────────

def _save_actions(json_str, actions_ref):
    global _config_lock
    try:
        data = json.loads(json_str)
        if not isinstance(data, dict):
            data = {"button_override": False, "buttons": {}, "taps": {}}
        if "buttons" in data or "taps" in data:
            legacy_buttons = data.pop("buttons", {})
            legacy_taps = data.pop("taps", {})
            data["modes"] = {
                "Default": {
                    "buttons": legacy_buttons,
                    "taps": legacy_taps,
                    "led": {"effect": "solid", "color": "FFFFFF", "brightness": 128}
                }
            }
            data["current_mode"] = "Default"
            
        with _config_lock:
            ACTIONS_PATH.parent.mkdir(parents=True, exist_ok=True)
            tmp_path = ACTIONS_PATH.with_suffix(".tmp")
            with open(tmp_path, "w") as f:
                json.dump(data, f, indent=2)
            os.replace(tmp_path, ACTIONS_PATH)
            actions_ref[0] = data
        print(f"[config] saved {ACTIONS_PATH}")
        return True
    except Exception as e:
        print(f"[config] save error: {e}")
        return False

async def ws_handler(websocket, actions_ref):
    _ws_clients.add(websocket)
    print(f"[ws] client connected ({len(_ws_clients)} total)")
    try:
        async for message in websocket:
            if message.startswith("actions "):
                ok = await asyncio.to_thread(_save_actions, message[8:], actions_ref)
                await websocket.send("OK actions saved" if ok else "ERR actions save failed")
            elif message == "actions_get":
                await websocket.send("ACTIONS:" + json.dumps(actions_ref[0]))
            else:
                await _serial_queue.put(message)
    except websockets.exceptions.ConnectionClosed:
        pass
    finally:
        _ws_clients.discard(websocket)
        print(f"[ws] client disconnected ({len(_ws_clients)} total)")

# ── Main ──────────────────────────────────────────────────────────────────────

async def main():
    global _loop, _serial_queue
    _loop = asyncio.get_running_loop()
    _serial_queue = asyncio.Queue()

    main_task = asyncio.current_task()

    def handle_signal():
        print("[main] signal received, cancelling main task")
        main_task.cancel()

    if sys.platform != "win32":
        _loop.add_signal_handler(signal.SIGINT, handle_signal)
        _loop.add_signal_handler(signal.SIGTERM, handle_signal)

    global _actions_ref
    _actions_ref[0] = load_actions()
    actions_ref = _actions_ref

    threading.Thread(target=serial_thread,  args=(actions_ref,), daemon=True).start()
    threading.Thread(target=hid_thread,     args=(actions_ref,), daemon=True).start()
    threading.Thread(target=config_watcher, args=(actions_ref,), daemon=True).start()
    threading.Thread(target=volume_watcher, daemon=True).start()

    asyncio.create_task(serial_writer())

    unix_server = None
    socket_path = None
    if sys.platform not in ("win32", "darwin"):
        try:
            # Unix Socket Setup
            socket_path = Path(f"/run/user/{os.getuid()}/spnav.sock")
            socket_path.parent.mkdir(parents=True, exist_ok=True)
            if socket_path.exists():
                try:
                    socket_path.unlink()
                except Exception as e:
                    print(f"[sock] failed to unlink stale socket: {e}")

            print(f"[sock] server starting on {socket_path}")
            unix_server = await asyncio.start_unix_server(handle_socket_client, path=str(socket_path))
        except Exception as e:
            print(f"[sock] error setting up unix socket: {e}")

    handler = lambda ws: ws_handler(ws, actions_ref)
    print(f"[ws] server starting on ws://{WS_HOST}:{WS_PORT}")
    try:
        async with websockets.serve(handler, WS_HOST, WS_PORT):
            await asyncio.Future()  # run forever
    except asyncio.CancelledError:
        pass
    finally:
        print("[sock] server shutting down")
        for writer in list(_socket_clients):
            try:
                writer.close()
            except Exception:
                pass
        if unix_server:
            unix_server.close()
            try:
                loop = asyncio.get_running_loop()
                if loop.is_running():
                    await unix_server.wait_closed()
            except RuntimeError:
                pass
        if socket_path and socket_path.exists():
            try:
                socket_path.unlink()
            except Exception as e:
                print(f"[sock] failed to unlink socket on shutdown: {e}")

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        print("[main] keyboard interrupt, exiting")
